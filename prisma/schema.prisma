generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  engineType      = "library"
}

datasource db {
  provider = "postgresql"
  extensions = [vector]
}

model Concept {
  id                 Int                    @id @default(autoincrement())
  slug               String                 @unique @db.VarChar(255)
  name               String                 @db.VarChar(255)
  category           String
  subCategory        String                 @map("sub_category") @db.VarChar(255)
  description        String
  logic              String
  appeal             String
  examples           String[]               @default([])
  notes              String?
  levels             Json?                  @default("[]")
  weight             Float                  @default(1.0)
  rawInput           String?                @map("raw_input")
  metadata           Json?
  isVerified         Boolean                @default(false) @map("is_verified")
  updatedAt          DateTime               @default(now()) @updatedAt @map("updated_at")
  embedding          Unsupported("vector(1024)")?
  conflictsInitiated ConceptConflict[]      @relation("ConceptA")
  conflictsReceived  ConceptConflict[]      @relation("ConceptB")
  outgoingEdges      ConceptEdge[]          @relation("SourceConcept")
  incomingEdges      ConceptEdge[]          @relation("TargetConcept")
  workConcepts       WorkConcept[]

  @@map("concepts")
}

model ConceptConflict {
  id         Int            @id @default(autoincrement())
  type       ConflictType   @default(LOGICAL)
  source     ConflictSource @default(MANUAL)
  reason     String?
  severity   Float          @default(1.0)
  conceptAId Int            @map("concept_a_id")
  conceptBId Int            @map("concept_b_id")
  conceptA   Concept        @relation("ConceptA", fields: [conceptAId], references: [id], onDelete: Cascade)
  conceptB   Concept        @relation("ConceptB", fields: [conceptBId], references: [id], onDelete: Cascade)

  @@unique([conceptAId, conceptBId])
  @@map("concept_conflicts")
}

model ConceptEdge {
  id              Int     @id @default(autoincrement())
  weight          Float
  type            EdgeType @default(SEMANTIC)
  sourceConceptId Int     @map("source_concept_id")
  targetConceptId Int     @map("target_concept_id")
  source          Concept @relation("SourceConcept", fields: [sourceConceptId], references: [id], onDelete: Cascade)
  target          Concept @relation("TargetConcept", fields: [targetConceptId], references: [id], onDelete: Cascade)

  @@unique([sourceConceptId, targetConceptId])
  @@map("concept_edges")
}

enum ConflictType {
  LOGICAL
}

enum EdgeType {
  SEMANTIC
}

enum ConflictSource {
  MANUAL
  MATHEMATICAL
  AI_GENERATED
}

model Author {
  id              Int      @id @default(autoincrement())
  openLibraryId   String   @unique @map("open_library_id")
  name            String
  bio             String?  @db.Text
  rawApiResponse  Json?    @map("raw_api_response")
  
  centroid        Unsupported("vector(1024)")? 
  
  works           Work[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  isVerified      Boolean  @default(false) @map("is_verified")

  @@map("authors")
}

model Work {
  id              Int      @id @default(autoincrement())
  title           String
  description     String?  @db.Text
  rawApiResponse  Json?    @map("raw_api_response")
  embedding       Unsupported("vector(1024)")?
  
  authorId        Int      @map("author_id")
  author          Author   @relation(fields: [authorId], references: [id])
  
  isVerified      Boolean  @default(false) @map("is_verified")

  workConcepts    WorkConcept[] 
  workSeries      WorkSeries[]

  @@map("works")
}

model Series {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  description     String?  @db.Text
  
  works           WorkSeries[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("series")
}

model WorkSeries {
  id              Int      @id @default(autoincrement())
  workId          Int      @map("work_id")
  seriesId        Int      @map("series_id")
  order           Int?     // Sequence in series
  
  work            Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  series          Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([workId, seriesId])
  @@map("work_series")
}

model WorkConcept {
  id         Int      @id @default(autoincrement())
  workId     Int      @map("work_id")
  conceptId  Int      @map("concept_id")
  
  similarity Float    
  isVerified Boolean  @default(false) @map("is_verified")

  work       Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  concept    Concept  @relation(fields: [conceptId], references: [id])

  @@unique([workId, conceptId])
  @@map("work_concepts")
}